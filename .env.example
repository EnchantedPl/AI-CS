# =========================
# App
# =========================
APP_NAME=ai-cs-demo
APP_ENV=dev
APP_PORT=8000
LOG_LEVEL=INFO
ENABLE_DEBUG=true
# Demo deterministic chain switch:
# - true: fixed question -> fixed intent/mock RAG/mock answer (interview demo)
# - false: dynamic routing/retrieval/generation
# - when true, complex aftersales action follows a stable loop:
#   action1(风控审批) -> 人工同意 -> action2(执行退款) -> 人工同意 -> 结束
# - KPI 演示脚本 scripts/generate_kpi_demo_dataset.py 会读取该开关并在报告中标注
DEMO_FIXED_SCENARIO=true

# =========================
# Postgres / pgvector
# =========================
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=ai_cs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# =========================
# Redis
# =========================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =========================
# LiteLLM Router (DashScope preferred)
# =========================
LLM_PROVIDER=litellm
LLM_MODE=cloud
LLM_MODEL=openai/qwen-turbo
LLM_FALLBACK_MODELS=ollama/qwen2.5:0.5b
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=

# Local LLM runtime (without Docker, Ollama on host)
LOCAL_LLM_MODEL=ollama/qwen2.5:0.5b
LOCAL_LLM_FALLBACK_MODELS=
LOCAL_LLM_API_BASE=http://127.0.0.1:11434
LOCAL_LLM_API_KEY=

# Cloud LLM runtime (DashScope-compatible)
CLOUD_LLM_MODEL=openai/qwen-turbo
CLOUD_LLM_FALLBACK_MODELS=ollama/qwen2.5:0.5b
CLOUD_LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
CLOUD_LLM_API_KEY=
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SEC=1.5
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=256
LLM_MAX_CONTEXT_CHARS=1200
LLM_DISABLE_PROXY_FOR_API=true

# Optional shared key for DashScope
DASHSCOPE_API_KEY=

# =========================
# Embedding
# =========================
EMBEDDING_MODE=cloud
EMBEDDING_PROVIDER=litellm
EMBEDDING_MODEL=openai/text-embedding-v3
EMBEDDING_FALLBACK_MODELS=
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT=60
EMBEDDING_BATCH_SIZE=10
EMBEDDING_DIM=1024
EMBEDDING_DISABLE_PROXY_FOR_API=true

# Local embedding runtime (free, on-device)
LOCAL_EMBEDDING_PROVIDER=huggingface
LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
LOCAL_EMBEDDING_DIM=384
LOCAL_EMBEDDING_BATCH_SIZE=32

# Cloud embedding runtime (DashScope-compatible)
CLOUD_EMBEDDING_PROVIDER=litellm
CLOUD_EMBEDDING_MODEL=openai/text-embedding-v3
CLOUD_EMBEDDING_DIM=1024
CLOUD_EMBEDDING_BATCH_SIZE=10
DEFAULT_LANGUAGE=zh
CACHE_REGION=global

# =========================
# RAG
# =========================
RAG_TOP_K=2
RAG_RERANK_TOP_K=4
RAG_ENABLE_RERANK=false
RAG_RERANK_PROVIDER=local
RAG_RERANK_MODEL=BAAI/bge-reranker-base
RAG_RERANK_CANDIDATES=20
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_ENABLE_RERANK=false
RAG_CHUNK_STRATEGY=fixed
RAG_TABLE_NAME=kb_chunks
RAG_RETRIEVAL_MODE=hybrid
RAG_VECTOR_TOP_K=5
RAG_KEYWORD_TOP_K=5
RAG_RRF_K=60
RAG_RRF_VECTOR_WEIGHT=0.7
RAG_RRF_KEYWORD_WEIGHT=0.3
RAG_AUTO_RESET_ON_EMBEDDING_CHANGE=true

# =========================
# Routing / Risk
# =========================
INTENT_CONF_THRESHOLD=0.65
RISK_HIGH_FORCE_HUMAN=true
RATE_LIMIT_REQ_PER_MIN=120
RATE_LIMIT_TOKENS_PER_MIN=120000
# High-priority bucket (risk/resume/rewind etc.) uses dedicated larger quota.
RATE_LIMIT_REQ_PER_MIN_HIGH=180
RATE_LIMIT_TOKENS_PER_MIN_HIGH=180000
# Degrade trigger ratios based on remaining quota ratio.
DEGRADE_SOFT_RATIO_HIGH=0.18
DEGRADE_HARD_RATIO_HIGH=0.08
DEGRADE_SOFT_RATIO_LOW=0.28
DEGRADE_HARD_RATIO_LOW=0.14
MAX_INFLIGHT_REQUESTS=24
CONCURRENCY_GATE_WAIT_SECONDS=0.8
WORKFLOW_TIMEOUT_SECONDS=35
WORKFLOW_RETRY_ON_ERROR=1
WORKFLOW_RETRY_BACKOFF_SECONDS=0.4
WORKFLOW_DEGRADE_ON_ERROR=true
CACHE_LAYER_TIMEOUT_SECONDS=1.8
CACHE_LAYER_RETRY=1
CACHE_LAYER_RETRY_BACKOFF_SECONDS=0.2
MEMORY_LAYER_TIMEOUT_SECONDS=2.5
MEMORY_LAYER_RETRY=1
MEMORY_LAYER_RETRY_BACKOFF_SECONDS=0.2
RAG_LAYER_TIMEOUT_SECONDS=2.2
RAG_LAYER_RETRY=1
RAG_LAYER_RETRY_BACKOFF_SECONDS=0.2
TOOL_LAYER_TIMEOUT_SECONDS=1.5
TOOL_LAYER_RETRY=1
TOOL_LAYER_RETRY_BACKOFF_SECONDS=0.15
LLM_LAYER_TIMEOUT_SECONDS=60
LLM_LAYER_RETRY=0
LLM_LAYER_RETRY_BACKOFF_SECONDS=0.3
# Route-target dynamic budget override examples (optional):
# Supported route keys: FAQ / PRODUCT_INFO / AFTERSALES / RISK_QUERY
# CACHE_LAYER_TIMEOUT_SECONDS_AFTERSALES=2.8
# MEMORY_LAYER_TIMEOUT_SECONDS_AFTERSALES=3.5
# RAG_LAYER_TIMEOUT_SECONDS_PRODUCT_INFO=2.6
# TOOL_LAYER_TIMEOUT_SECONDS_AFTERSALES=2.0
# LLM_LAYER_TIMEOUT_SECONDS_AFTERSALES=90
# LLM_LAYER_RETRY_AFTERSALES=1

# Guardrail
GUARDRAIL_MAX_OUTPUT_CHARS=1200
GUARDRAIL_BANNED_TERMS=
GUARDRAIL_REQUIRE_CITATION_ROUTES=faq,product_info
PROMPT_INJECTION_ACTION=sanitize

# =========================
# Cache
# =========================
ENABLE_L1_CACHE=true
ENABLE_L2_SEM_CACHE=true
ENABLE_L3_RAG_CACHE=true

L1_TTL_SECONDS=1800
L2_TTL_SECONDS=7200
L3_TTL_SECONDS=3600

SEMANTIC_TOP_K=5
SEMANTIC_THRESHOLD_LOW=0.82
SEMANTIC_THRESHOLD_HIGH=0.90
L2_GRAY_PG_TOPK=10
L2_GRAY_ENABLE_RERANK=false
L2_GRAY_RERANK_PROVIDER=local
L2_GRAY_RERANK_MODEL=BAAI/bge-reranker-base
L2_GRAY_RERANK_CANDIDATES=10
L2_GRAY_RERANK_TOPK=3
L2_GRAY_SECOND_THRESHOLD=0.86
CACHE_ADMISSION_ENABLED=true
CACHE_ADMISSION_MIN_ANSWER_LEN=20
CACHE_ADMISSION_MIN_CITATIONS=1
CACHE_ADMISSION_BLOCKED_DOMAINS=risk_query
CACHE_CIRCUIT_FAIL_THRESHOLD=3
CACHE_CIRCUIT_COOLDOWN_SECONDS=30

# Version gating
PROMPT_VERSION=v1
KB_VERSION=v1
POLICY_VERSION=v1
# Demo: 回退后根据人工理由/证据重评并生成引导话术（mock 开关）
AFTERSALES_REWIND_FEEDBACK_MOCK_ENABLED=true

# =========================
# Memory
# =========================
MEMORY_RECENT_TURNS=8
MEMORY_EPISODIC_MAX=5
MEMORY_WRITE_SCORE_THRESHOLD=0.60
MEMORY_SHORT_TTL_SECONDS=86400
MEMORY_LONG_TTL_SECONDS=2592000
MEMORY_L3_TTL_SECONDS=604800
MEMORY_READ_TOP_K=6
ENABLE_MEMORY=true
CONTEXT_TOTAL_BUDGET_CHARS=2000
CONTEXT_MEMORY_BUDGET_RATIO=0.3
MEMORY_SUMMARIZER_ENABLED=false
MEMORY_SUMMARY_MAX_CHARS=800
MEMORY_DEDUP_ENABLED=true
MEMORY_DEDUP_SIM_THRESHOLD_LONG=0.92
MEMORY_DEDUP_SIM_THRESHOLD_L3=0.95
CONTEXT_MEMORY_SHORT_RATIO=0.5
CONTEXT_MEMORY_LONG_RATIO=0.3
CONTEXT_MEMORY_L3_RATIO=0.2
CONTEXT_MEMORY_SUMMARIZER_ENABLED=false
CONTEXT_MEMORY_SUMMARY_MAX_CHARS=180

# =========================
# Observability
# =========================
ENABLE_PROMETHEUS=true
METRICS_PATH=/metrics
REDIS_SLOW_COMMAND_MS=50
PG_SLOW_QUERY_MS=100
PG_MAX_CONNECTIONS=20

ENABLE_LANGSMITH=false
LANGSMITH_API_KEY=
# 可选：与 LANGSMITH_API_KEY 相同；部分 LangChain 集成只读 LANGCHAIN_API_KEY（启用 Tracing 时代码会自动 setdefault）
LANGCHAIN_API_KEY=
LANGSMITH_PROJECT=ai-cs-demo
# LangSmith API 基址：美区默认 https://api.smith.langchain.com；EU 为 https://api.eu.smith.langchain.com
# 若脚本报 SSLEOF/SSL EOF，优先去掉系统代理或改用美区（须与账号/数据集区域一致）
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Layered Replay
ENABLE_LAYERED_REPLAY=true
REPLAY_SCHEMA_VERSION=v1
REPLAY_LAYER_SPEC_VERSION=v1_5layer

# =========================
# Evaluation
# =========================
EVAL_DATA_PATH=./data/eval/eval_set.jsonl
EVAL_OUTPUT_DIR=./data/eval/reports
ENABLE_LLM_AS_JUDGE=false
JUDGE_MODEL=qwen2.5:7b
